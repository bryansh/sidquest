{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sidquest",
  "version": "0.3.4",
  "identifier": "com.bryan.sidquest",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "sidquest",
        "label": "main",
        "width": 800,
        "height": 600,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://bryansh.github.io/sidquest-updates/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyOUZBM0RBMjQ2MzU5NDMKUldSRFdXTWsycU9mUXJtUlFwdXljekRvaUdDTzVqRTFWd3BBRTdiR2g2TDZXeHI1Z3hGUEYvTm0K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
